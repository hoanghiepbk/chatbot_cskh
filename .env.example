# Anthropic API key — dùng cho agent (Sonnet) + guardrail/judge (Haiku)
ANTHROPIC_API_KEY=

# Supabase project URL (https://<project-ref>.supabase.co)
SUPABASE_URL=

# Service role key — CHỈ dùng server-side (agent service, eval runner)
SUPABASE_SERVICE_ROLE_KEY=

# Anon key — dùng cho console + widget (client-side, qua RLS)
SUPABASE_ANON_KEY=

# Salt cho sha256(salt + phone_E164) → customer_profiles.phone_hash
# Seed demo dùng 'DEMO_SALT' — BẮT BUỘC đổi ở production
PHONE_HASH_SALT=
