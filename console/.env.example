# TIP-014 console env. Copy to `.env` for dev. NEVER put the Supabase service
# role key here — sensitive data goes through the agent staff API (Bearer).

# Agent staff API base. EMPTY in dev → console calls relative /staff,/chat and
# Vite proxies them (see VITE_AGENT_PROXY_TARGET). Set an absolute URL for a
# built/production console (then the agent must allow that origin via CORS).
VITE_AGENT_URL=

# Dev-only: where the Vite proxy forwards /staff and /chat.
VITE_AGENT_PROXY_TARGET=http://127.0.0.1:8000

# Optional: pre-fill the login token in dev. The login screen still overrides it.
VITE_STAFF_TOKEN=

# Supabase project — ANON key ONLY (public by design). Powers Realtime push
# (conversations are anon-readable via RLS) and masked messages_public reads for
# the live chat. If unset, the console falls back to staff-API polling and the
# live-chat history panel is disabled.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
