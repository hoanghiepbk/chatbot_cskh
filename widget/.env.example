# TIP-014w widget env. Copy to `.env` for dev. NEVER put a service_role key here
# — the widget only ever uses the Supabase ANON key (public by design).

# Agent base URL. EMPTY in dev → widget calls relative /chat and Vite proxies it
# (see VITE_AGENT_PROXY_TARGET). Set an absolute URL for a built/prod widget.
VITE_AGENT_URL=

# Dev-only: where the Vite proxy forwards /chat (incl. the SSE stream).
VITE_AGENT_PROXY_TARGET=http://127.0.0.1:8000

# Supabase — ANON key ONLY. Powers human-mode Realtime (staff messages via
# messages_public + conversation mode flips). If unset, the widget polls
# messages_public every 3s instead; agent-mode chat works without it.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
